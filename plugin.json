{
  "workflow": {
    "nodes": [
      {
        "id": "plugin-metadata",
        "type": "modifier",
        "position": {
          "x": 240,
          "y": 160
        },
        "data": {
          "modifier": {
            "name": "Polyhedral Template Matching",
            "key": "polyhedral-template-matching",
            "icon": "HiCubeTransparent",
            "author": "Rodolfo Herrera",
            "license": "MIT",
            "version": "1.0.5",
            "homepage": "https://github.com/rodyherrera/Volterra",
            "description": "Ejecuta PTM, exporta structure_type por atomo y genera los artefactos de cluster graph consumibles por OpenDXA."
          }
        }
      },
      {
        "id": "plugin-arguments",
        "type": "arguments",
        "position": {
          "x": 528,
          "y": 208
        },
        "data": {
          "arguments": {
            "arguments": [
              {
                "argument": "crystal_structure",
                "type": "select",
                "label": "Crystal Structure",
                "default": "FCC",
                "options": [
                  {
                    "key": "BCC",
                    "label": "Body-Centered Cubic (BCC)"
                  },
                  {
                    "key": "FCC",
                    "label": "Face-Centered Cubic (FCC)"
                  },
                  {
                    "key": "HCP",
                    "label": "Hexagonal Close Packed (HCP)"
                  },
                  {
                    "key": "SC",
                    "label": "Simple Cubic (SC)"
                  },
                  {
                    "key": "CUBIC_DIAMOND",
                    "label": "Cubic Diamond"
                  },
                  {
                    "key": "HEX_DIAMOND",
                    "label": "Hex Diamond"
                  }
                ]
              },
              {
                "argument": "rmsd",
                "type": "number",
                "label": "RMSD",
                "default": 0.1,
                "min": 0,
                "step": 0.01
              },
              {
                "argument": "dissolve_small_clusters",
                "type": "boolean",
                "label": "Dissolve Small Clusters",
                "default": false
              }
            ]
          }
        }
      },
      {
        "id": "trajectory-context",
        "type": "context",
        "position": {
          "x": 816,
          "y": 160
        },
        "data": {
          "context": {
            "source": "trajectory_dumps"
          }
        }
      },
      {
        "id": "foreach-trajectory-dumps",
        "type": "forEach",
        "position": {
          "x": 1088,
          "y": 208
        },
        "data": {
          "forEach": {
            "iterableSource": "{{ trajectory-context.trajectory_dumps }}"
          }
        }
      },
      {
        "id": "analysis-entrypoint",
        "type": "entrypoint",
        "position": {
          "x": 1392,
          "y": 208
        },
        "data": {
          "entrypoint": {
            "type": "executable",
            "binary": "polyhedral-template-matching",
            "binaryObjectPath": "__UPLOAD_BINARY_OBJECT_PATH__",
            "binaryFileName": "polyhedral-template-matching",
            "arguments": "{{ foreach-trajectory-dumps.currentValue.path }} {{ foreach-trajectory-dumps.outputPath }} {{ plugin-arguments.as_str }}",
            "timeout": -1,
            "outputs": [
              {
                "name": "annotatedDump",
                "sourceSuffix": "_annotated.dump",
                "contentType": "text/plain",
                "description": "Per-atom structure annotated LAMMPS dump emitted by PTM."
              },
              {
                "name": "clustersTable",
                "sourceSuffix": "_clusters.table",
                "contentType": "text/plain",
                "description": "Cluster graph table required by OpenDXA / LineReconstructionDXA / ElasticStrain."
              },
              {
                "name": "clustersTransitions",
                "sourceSuffix": "_cluster_transitions.table",
                "contentType": "text/plain",
                "description": "Cluster transitions table required by OpenDXA / LineReconstructionDXA / ElasticStrain."
              }
            ]
          }
        }
      },
      {
        "id": "structure-identification-exposure",
        "type": "exposure",
        "position": {
          "x": 1712,
          "y": 208
        },
        "data": {
          "exposure": {
            "name": "Structure Identification",
            "icon": "HiCubeTransparent",
            "results": "atoms.msgpack",
            "iterable": ""
          }
        }
      },
      {
        "id": "structure-identification-export",
        "type": "export",
        "position": {
          "x": 2032,
          "y": 208
        },
        "data": {
          "export": {
            "exporter": "AtomisticExporter",
            "type": "glb"
          }
        }
      },
      {
        "id": "ptm-analysis-exposure",
        "type": "exposure",
        "position": {
          "x": 1712,
          "y": 336
        },
        "data": {
          "exposure": {
            "name": "PTM Analysis",
            "icon": "HiCube",
            "results": "ptm_analysis.msgpack",
            "iterable": "",
            "hasListing": false
          }
        }
      },
      {
        "id": "structure-counts-chart-exposure",
        "type": "exposure",
        "position": {
          "x": 1712,
          "y": 464
        },
        "data": {
          "exposure": {
            "name": "Structure Counts Chart",
            "icon": "HiChartBar",
            "results": "atoms.msgpack",
            "iterable": "",
            "hasListing": false
          }
        }
      },
      {
        "id": "structure-counts-chart-export",
        "type": "export",
        "position": {
          "x": 2032,
          "y": 464
        },
        "data": {
          "export": {
            "exporter": "ChartExporter",
            "type": "chart-png",
            "options": {
              "xAxisKey": "structure_counts.structure_name",
              "yAxisKey": "structure_counts.atom_count",
              "chartType": "bar",
              "title": "Structure counts",
              "xAxisLabel": "Structure",
              "yAxisLabel": "Atoms",
              "backgroundColor": "#ffffff",
              "lineColor": "#2563eb",
              "fillColor": "rgba(37, 99, 235, 0.35)",
              "showLegend": false,
              "showGrid": true
            }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "edge-metadata-arguments",
        "source": "plugin-metadata",
        "sourceHandle": "output",
        "target": "plugin-arguments",
        "targetHandle": "input"
      },
      {
        "id": "edge-arguments-context",
        "source": "plugin-arguments",
        "sourceHandle": "output",
        "target": "trajectory-context",
        "targetHandle": "input"
      },
      {
        "id": "edge-context-foreach",
        "source": "trajectory-context",
        "sourceHandle": "output",
        "target": "foreach-trajectory-dumps",
        "targetHandle": "input"
      },
      {
        "id": "edge-foreach-entrypoint",
        "source": "foreach-trajectory-dumps",
        "sourceHandle": "output",
        "target": "analysis-entrypoint",
        "targetHandle": "input"
      },
      {
        "id": "edge-entrypoint-structure-identification",
        "source": "analysis-entrypoint",
        "sourceHandle": "output",
        "target": "structure-identification-exposure",
        "targetHandle": "input"
      },
      {
        "id": "edge-structure-identification-export",
        "source": "structure-identification-exposure",
        "sourceHandle": "output",
        "target": "structure-identification-export",
        "targetHandle": "input"
      },
      {
        "id": "edge-entrypoint-ptm-analysis-exposure",
        "source": "analysis-entrypoint",
        "sourceHandle": "output",
        "target": "ptm-analysis-exposure",
        "targetHandle": "input"
      },
      {
        "id": "edge-analysis-entrypoint-structure-counts-chart-exposure",
        "source": "analysis-entrypoint",
        "sourceHandle": "output",
        "target": "structure-counts-chart-exposure",
        "targetHandle": "input"
      },
      {
        "id": "edge-structure-counts-chart-exposure-structure-counts-chart-export",
        "source": "structure-counts-chart-exposure",
        "sourceHandle": "output",
        "target": "structure-counts-chart-export",
        "targetHandle": "input"
      }
    ]
  }
}
